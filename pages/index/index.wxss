/* pages/index/index.wxss */
.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 60rpx 40rpx;
  box-sizing: border-box;
}

.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.logo {
  font-size: 120rpx;
  margin-bottom: 20rpx;
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

.title {
  font-size: 64rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #667eea 0%, #f093fb 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
}

.action-area {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  max-width: 500rpx;
  height: 100rpx;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  margin-bottom: 20rpx;
  transition: all 0.3s ease;
}

.btn-primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  box-shadow: 0 10rpx 30rpx rgba(102, 126, 234, 0.4);
}

.btn-primary:active {
  transform: scale(0.98);
  box-shadow: 0 5rpx 15rpx rgba(102, 126, 234, 0.3);
}

.btn-outline {
  background: transparent;
  border: 2rpx solid #667eea;
  color: #667eea;
}

.btn-outline:active {
  background: rgba(102, 126, 234, 0.1);
}

.btn-secondary {
  background: rgba(255, 255, 255, 0.1);
  color: #ffffff;
  font-size: 28rpx;
  height: 80rpx;
}

.btn-icon {
  margin-right: 10rpx;
  font-size: 36rpx;
}

.divider {
  display: flex;
  align-items: center;
  width: 100%;
  max-width: 500rpx;
  margin: 30rpx 0;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: rgba(255, 255, 255, 0.2);
}

.divider-text {
  padding: 0 20rpx;
  color: rgba(255, 255, 255, 0.4);
  font-size: 24rpx;
}

.join-area {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.input {
  width: 100%;
  max-width: 500rpx;
  height: 100rpx;
  background: rgba(255, 255, 255, 0.08);
  border: 2rpx solid rgba(255, 255, 255, 0.15);
  border-radius: 50rpx;
  padding: 0 40rpx;
  color: #ffffff;
  font-size: 36rpx;
  text-align: center;
  letter-spacing: 8rpx;
  margin-bottom: 30rpx;
}

.input-placeholder {
  color: rgba(255, 255, 255, 0.4);
}

.room-list {
  width: 100%;
  max-width: 500rpx;
  margin-top: 60rpx;
}

.section-title {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-bottom: 20rpx;
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

.rooms {
  display: flex;
  flex-direction: column;
}

.room-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  padding: 24rpx 30rpx;
  margin-bottom: 16rpx;
}

.room-id {
  font-size: 32rpx;
  font-weight: 600;
  color: #667eea;
}

.room-info {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}