/* pages/room/room.wxss */
.container {
  min-height: 100vh;
  padding: 30rpx;
  box-sizing: border-box;
  background: #16213e;
}

.room-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  margin-bottom: 30rpx;
}

.room-id {
  font-size: 32rpx;
  color: #fff;
  font-weight: 600;
}

.phase-tag {
  padding: 8rpx 20rpx;
  background: #667eea;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.players-section {
  margin-bottom: 40rpx;
}

.section-title {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 20rpx;
}

.players-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.player-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.player-card.selected {
  border-color: #667eea;
  background: rgba(102, 126, 234, 0.2);
}

.player-card.dead {
  opacity: 0.4;
}

.player-avatar {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.player-name {
  font-size: 26rpx;
  color: #fff;
  margin-bottom: 8rpx;
}

.player-status {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
}

.actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 40rpx;
}

.btn {
  width: 100%;
  height: 90rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 45rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-judge {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.my-info {
  margin-top: 40rpx;
  text-align: center;
}

.my-id {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
}